# Adaptive Hybrid RAG Platform — environment variables
# Copy to .env and fill in values as needed.

# App
DEBUG=false

# Production AI models (flat env vars)
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
RERANKER_MODEL=BAAI/bge-reranker-base
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct

# LLM (OpenRouter is the production default)
LLM__PROVIDER=openrouter
LLM__MODEL=meta-llama/llama-3.1-8b-instruct
# LLM__OPENAI_API_KEY=
# LLM__GEMINI_API_KEY=
# LLM__GROQ_API_KEY=
# LLM__OPENROUTER_API_KEY=   # required for pydantic nested loading; or OPENROUTER_API_KEY
# LLM__OLLAMA_BASE_URL=http://localhost:11434

# Vector store
VECTOR_STORE__PROVIDER=faiss

# Sparse index
SPARSE_INDEX__PROVIDER=bm25
CHUNKING__OVERLAP_TOKENS=50
CHUNKING__STRATEGY=structure_aware

# Retrieval
RETRIEVAL__CONFIDENCE_THRESHOLD=0.65
RETRIEVAL__MAX_ESCALATIONS=3
RETRIEVAL__RERANK_TOP_K=5

# Answer generation
ANSWER_GENERATION__MAX_CONTEXT_TOKENS=2048

# Citation formatting
CITATION__EXCERPT_MAX_CHARS=200

# Storage
STORAGE__MAX_UPLOAD_BYTES=20971520

# Logging
LOGGING__LEVEL=INFO
LOGGING__JSON_LOGS=false

# Tests/eval only — use fake adapters for fast deterministic unit tests
# ADAPTIVE_RAG_FAKE_EMBEDDER=1
# ADAPTIVE_RAG_FAKE_RERANKER=1
# ADAPTIVE_RAG_FAKE_LLM=1
