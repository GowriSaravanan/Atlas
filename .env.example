# Adaptive Hybrid RAG Platform — environment variables
# Copy to .env and fill in values as needed.

# App
DEBUG=false
EVAL_MODE=false

# LLM (default: ollama)
LLM__PROVIDER=ollama
LLM__MODEL=llama3
LLM__OLLAMA_BASE_URL=http://localhost:11434
# LLM__OPENAI_API_KEY=
# LLM__GEMINI_API_KEY=
# LLM__GROQ_API_KEY=

# Vector store
VECTOR_STORE__PROVIDER=faiss

# Sparse index
SPARSE_INDEX__PROVIDER=bm25
CHUNKING__OVERLAP_TOKENS=50
CHUNKING__STRATEGY=structure_aware

# Tests: set ADAPTIVE_RAG_FAKE_EMBEDDER=1 to skip Sentence Transformers model load
# Tests/eval: set ADAPTIVE_RAG_FAKE_RERANKER=1 to preserve retrieval ordering in benchmarks
ADAPTIVE_RAG_FAKE_RERANKER=1

# Conversation
CONVERSATION__SUMMARY_THRESHOLD=10

# Reranker
RERANKER__MODEL_NAME=cross-encoder/ms-marco-MiniLM-L-6-v2
RETRIEVAL__RERANK_TOP_K=5

# Answer generation
ANSWER_GENERATION__MAX_CONTEXT_TOKENS=2048
ADAPTIVE_RAG_FAKE_LLM=1

# LLM
LLM__PROVIDER=ollama
LLM__MODEL=llama3

# Retrieval
RETRIEVAL__CONFIDENCE_THRESHOLD=0.65
RETRIEVAL__MAX_ESCALATIONS=3

# Logging
LOGGING__LEVEL=INFO
LOGGING__JSON_LOGS=false
